# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Public URL of the app (no trailing slash)
BASE_URL=https://games.alhajda.com

# Session encryption secret (use a long random string in production)
SESSION_SECRET=change-me-to-a-random-secret

# Set to production when deployed
NODE_ENV=production
