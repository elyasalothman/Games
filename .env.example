# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Public URL of the app (no trailing slash)
BASE_URL=https://games.alhajda.com

# Session encryption secret (use a long random string in production)
SESSION_SECRET=change-me-to-a-random-secret

# Use a persistent disk path in production (for example, a Render disk mounted at /var/data)
DB_PATH=/var/data/leaderboard.db

# Local testing (Google OAuth redirect must include this URL in Google Console):
# BASE_URL=http://localhost:3000
# DB_PATH=./leaderboard.db
# NODE_ENV=development
